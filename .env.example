NODE_ENV=development
PORT=4000
MATTER_RUNTIME_ENABLED=false
MQTT_RUNTIME_ENABLED=false
AUTH_PERSISTENCE_MODE=mongodb
HOME_PERSISTENCE_MODE=mongodb
PID_PERSISTENCE_MODE=mongodb
DEVICE_PERSISTENCE_MODE=mongodb
PROVISIONING_PERSISTENCE_MODE=mongodb
OTA_PERSISTENCE_MODE=mongodb
API_ACCESS_PERSISTENCE_MODE=mongodb
SCENE_PERSISTENCE_MODE=mongodb
SCENE_SCHEDULER_ENABLED=true
SCENE_SCHEDULER_COORDINATION_MODE=mongodb-lock
SCENE_SCHEDULER_INTERVAL_MS=30000
SCENE_SCHEDULER_LEASE_MS=60000
SCENE_SCHEDULER_INSTANCE_ID=
SCENE_RUNTIME_WORKER_ENABLED=true
SCENE_RUNTIME_WORKER_INTERVAL_MS=5000
SCENE_RUNTIME_WORKER_BATCH_SIZE=25
SCENE_RUNTIME_WORKER_VISIBILITY_TIMEOUT_MS=30000
SCENE_ACTION_WORKER_ENABLED=true
SCENE_ACTION_WORKER_INTERVAL_MS=5000
SCENE_ACTION_WORKER_BATCH_SIZE=25
SCENE_ACTION_WORKER_VISIBILITY_TIMEOUT_MS=30000
MONGODB_URI=mongodb://localhost:27017/jenix_iot
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
# SEC-01 — shared secret the admin console/tools must send as `x-admin-key` to reach
# /api/v1/admin/* (PID, OTA release publishing, API packages). Empty in production = admin
# surface is locked (503). Empty in dev/test = open for convenience.
ADMIN_API_KEY=
# SEC-02 — shared key firmware must send as the `x-device-key` header when posting
# telemetry. Empty in production = ingest is disabled (503). Empty in dev/test = open.
DEVICE_INGEST_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
MQTT_URL=mqtt://mqtt.iotsoft.in:1883
MQTT_CLIENT_ID=jenix-api-local
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TELEMETRY_TOPIC=jenix/runtime/telemetry
MQTT_SCHEDULE_TOPIC=jenix/runtime/schedule
MQTT_DEVICE_COMMAND_TOPIC=jenix/runtime/commands
MQTT_DEVICE_COMMAND_ACK_TOPIC=jenix/runtime/commands/ack
MQTT_NOTIFICATION_TOPIC=jenix/runtime/notifications
MQTT_OTA_REQUEST_TOPIC=jenix/runtime/ota
MQTT_OTA_ACK_TOPIC=jenix/runtime/ota/ack
OTA_DELIVERY_WORKER_ENABLED=true
OTA_DELIVERY_WORKER_INTERVAL_MS=5000
OTA_DELIVERY_WORKER_BATCH_SIZE=25
OTA_DELIVERY_WORKER_VISIBILITY_TIMEOUT_MS=30000
FCM_SERVER_KEY=
APP_PUBLIC_URL=https://app.iotsoft.in
API_PUBLIC_URL=https://api.iotsoft.in
